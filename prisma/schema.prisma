datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id              String        @id @default(uuid())
  username        String        @unique
  password        String
  name            String
  role            String        @default("Support") // Founder, Admin, Billing, Support, Moderator
  status          String        @default("Active") // Active, Suspended
  twoFactorSecret String?
  twoFactorEnabled Boolean      @default(false)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  logs            ActivityLog[]
}

model Customer {
  id            String     @id @default(uuid())
  name          String
  companyName   String?
  email         String     @unique
  phone         String?
  discord       String?
  gstNumber     String?
  country       String     @default("United States")
  address       String?
  notes         String?
  staffNotes    String?
  status        String     @default("Active") // Active, Suspended
  joinDate      DateTime   @default(now())
  totalOrders   Int        @default(0)
  totalSpending Float      @default(0.0)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  services      Service[]
  invoices      Invoice[]
  tickets       Ticket[]
}

model Service {
  id              String    @id @default(uuid())
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type            String    // VPS, VDS, Dedicated Server, Minecraft Hosting, FiveM, Bot, Web, etc.
  planName        String
  cpu             String
  ram             String
  storage         String
  bandwidth       String
  os              String?
  virtualization  String?
  location        String
  ipv4            String?
  ipv6            String?
  port            Int?
  username        String    @default("root")
  password        String
  panelUrl        String?
  panelUsername   String?
  panelPassword   String?
  provider        String
  nodeName        String?
  hostMachine     String?
  purchaseCost    Float     @default(0.0)
  sellingPrice    Float     @default(0.0)
  billingCycle    String    @default("Monthly") // Weekly, Monthly, Quarterly, SemiAnnual, Annual, Lifetime
  issueDate       DateTime  @default(now())
  nextRenewalDate DateTime
  expiryDate      DateTime
  autoRenewal     Boolean   @default(true)
  status          String    @default("Active") // Active, Suspended, Expired, Terminated, Pending
  internalNotes   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  serverId        String?
  server          Server?   @relation(fields: [serverId], references: [id], onDelete: SetNull)
  invoices        Invoice[]
  orders          Order[]
}

model Invoice {
  id              String    @id @default(uuid())
  invoiceNumber   String    @unique
  customerId      String
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  serviceId       String?
  service         Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  amount          Float
  tax             Float     @default(0.0)
  discount        Float     @default(0.0)
  paymentMethod   String    @default("Stripe")
  transactionId   String?
  issueDate       DateTime  @default(now())
  dueDate         DateTime
  paidDate        DateTime?
  status          String    @default("Pending") // Paid, Pending, Failed, Refunded, Cancelled
  recurring       Boolean   @default(false)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  payments        Payment[]
}

model Payment {
  id            String   @id @default(uuid())
  invoiceId     String?
  invoice       Invoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  customerId    String
  customerName  String
  email         String?
  amount        Float
  currency      String   @default("USD")
  gateway       String   // Stripe, PayPal, Razorpay, Crypto, UPI, BankTransfer, Cash
  transactionId String?
  status        String   @default("Completed") // Completed, Pending, Failed, Refunded
  notes         String?
  paidAt        DateTime @default(now())
  createdAt     DateTime @default(now())
}

model Order {
  id              String    @id @default(uuid())
  orderNumber     String    @unique
  customerId      String
  customerName    String
  email           String?
  serviceId       String?
  service         Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  product         String
  price           Float
  discount        Float     @default(0.0)
  coupon          String?
  paymentMethod   String
  invoiceNumber   String?
  status          String    @default("Pending") // Pending, Active, Completed, Cancelled, Refunded
  activationDate  DateTime?
  cancellationDate DateTime?
  refundStatus    String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Server {
  id           String    @id @default(uuid())
  name         String
  provider     String
  location     String
  cpu          Int
  ram          Int
  storage      Int
  ips          String
  monthlyCost  Float     @default(0.0)
  renewalDate  DateTime
  status       String    @default("Active") // Active, Maintenance, Suspended
  services     Service[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model ProviderRecord {
  id          String   @id @default(uuid())
  name        String
  loginUrl    String
  username    String
  password    String
  renewalDate DateTime
  monthlyCost Float    @default(0.0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Ticket {
  id         String   @id @default(uuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  title      String
  department String   @default("General")
  status     String   @default("Open") // Open, Pending, Answered, Closed
  priority   String   @default("Medium") // Low, Medium, High, Critical
  messages   String   // JSON serialized
  assignedTo String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  category    String   // HostingNodes, Domains, Licenses, Marketing, Salary, Software, Miscellaneous
  amount      Float
  vendor      String?
  description String?
  invoiceRef  String?
  paymentDate DateTime
  recurring   Boolean  @default(false)
  receiptUrl  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Domain {
  id            String   @id @default(uuid())
  domain        String   @unique
  registrar     String?
  customerId    String?
  expiryDate    DateTime?
  renewalDate   DateTime?
  autoRenewal   Boolean  @default(true)
  nameservers   String?
  dnsRecords    String?  // JSON
  status        String   @default("Active")
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  staffName String
  action    String
  details   String
  ipAddress String?
  timestamp DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  type      String   // Renewal, Expired, FailedPayment, NewCustomer, NewInvoice, TicketCreated
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SystemSettings {
  id              String @id @default("main")
  companyName     String @default("Zyphron Cloud Solutions")
  logoUrl         String?
  invoicePrefix   String @default("INV-")
  gstNumber       String?
  currency        String @default("USD")
  timeZone        String @default("UTC")
  emailTemplate   String @default("")
  reminderTemplate String @default("")
  smtpHost        String?
  smtpPort        Int?
  smtpUser        String?
  smtpPass        String?
  webhookUrl      String?
  telegramBot     String?
  stripeKey       String?
  razorpayKey     String?
  paypalKey       String?
  paymenterUrl    String?
  paymenterKey    String?
  pterodactylUrl  String?
  pterodactylKey  String?
  updatedAt       DateTime @updatedAt
}
